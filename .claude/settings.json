{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Glob",
      "Grep",
      "LS",
      "Edit(<project>/**)",
      "Write(<project>/**)",
      "MultiEdit(<project>/**)",
      "Delete(<project>/**)",
      "Write(/tmp/**)",
      "Edit(/tmp/**)",
      "NotebookRead",
      "NotebookEdit(<project>/**/*.ipynb)",
      "mcp__*",
      "Skill(*)",
      "Task(*)",
      "Agent(*)",
      "TodoRead",
      "TodoWrite",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
   "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tdd-skill-forced-eval.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/agent-visibility.sh"
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "claude-context",
    "context7",
    "sequentialthinking"
  ],
  "enabledPlugins": {
	"everything-claude-code@everything-claude-code": true,
	"typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-team@martian-engineering": true,
    "context7-plugin@context7-marketplace": true,
    "coderabbit@claude-plugins-official": true,
    "desktop-commander@claude-plugins-official": true
	  },
  "worktreeDir": "project-root/.worktrees/",
  "planDirectory": "project-root/.claude/plans"
}
